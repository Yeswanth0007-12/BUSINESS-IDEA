# ============================================
# PackOptima Environment Configuration
# Staging Environment
# ============================================
# 
# IMPORTANT: 
# - Copy this file to .env.staging
# - Fill in all values with staging credentials
# - Staging should mirror production configuration
#
# ============================================

# ============================================
# Database Configuration
# ============================================
DATABASE_URL=postgresql://packoptima_staging:CHANGE_THIS_PASSWORD@staging-db-host:5432/packoptima_staging
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=5
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=3600

# ============================================
# Redis Configuration
# ============================================
REDIS_URL=redis://:CHANGE_THIS_PASSWORD@staging-redis-host:6379/0
CELERY_BROKER_URL=redis://:CHANGE_THIS_PASSWORD@staging-redis-host:6379/1
CELERY_RESULT_BACKEND=redis://:CHANGE_THIS_PASSWORD@staging-redis-host:6379/2

# ============================================
# Security
# ============================================
# Generate with: openssl rand -hex 32
API_SECRET_KEY=CHANGE_THIS_TO_RANDOM_32_CHAR_STRING
JWT_SECRET_KEY=CHANGE_THIS_TO_DIFFERENT_RANDOM_32_CHAR_STRING
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================
# CORS Configuration
# ============================================
ALLOWED_ORIGINS=https://staging-app.packoptima.ai,https://staging.packoptima.ai

# ============================================
# Application Configuration
# ============================================
ENVIRONMENT=staging
DEBUG=false
APP_NAME=PackOptima
APP_VERSION=2.0.0

# ============================================
# Server Configuration
# ============================================
HOST=0.0.0.0
PORT=8000
WORKERS=2

# ============================================
# Feature Flags
# ============================================
ENABLE_QUEUE_SYSTEM=true
ENABLE_BULK_UPLOAD=true
ENABLE_WEBHOOKS=true
ENABLE_WAREHOUSE_API=true

# ============================================
# Optimization Defaults
# ============================================
DEFAULT_COURIER_RATE=2.5
MAX_BULK_UPLOAD_SIZE_MB=10
MAX_BULK_UPLOAD_ROWS=10000

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_STANDARD_RPM=100
RATE_LIMIT_PREMIUM_RPM=500
RATE_LIMIT_ENTERPRISE_RPM=2000

# ============================================
# Celery Worker Configuration
# ============================================
CELERY_WORKER_CONCURRENCY=2
CELERY_WORKER_MAX_TASKS_PER_CHILD=1000
CELERY_TASK_TIME_LIMIT=300
CELERY_TASK_SOFT_TIME_LIMIT=270

# ============================================
# Monitoring & Error Tracking
# ============================================
SENTRY_DSN=https://YOUR_SENTRY_KEY@sentry.io/YOUR_STAGING_PROJECT_ID
SENTRY_ENVIRONMENT=staging
SENTRY_TRACES_SAMPLE_RATE=0.5

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=DEBUG
LOG_FORMAT=json
LOG_FILE=/var/log/packoptima/staging.log

# ============================================
# Email Configuration
# ============================================
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=YOUR_SENDGRID_API_KEY
SMTP_FROM=staging@packoptima.ai

# ============================================
# Backup Configuration
# ============================================
BACKUP_S3_BUCKET=packoptima-staging-backups
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_KEY
AWS_REGION=us-east-1

# ============================================
# Performance Tuning
# ============================================
DB_POOL_PRE_PING=true
DB_ECHO=false
REDIS_MAX_CONNECTIONS=25
REQUEST_TIMEOUT=120

# ============================================
# Security Headers
# ============================================
ENABLE_SECURITY_HEADERS=true
ENABLE_HSTS=false

# ============================================
# Webhook Configuration
# ============================================
WEBHOOK_TIMEOUT=30
WEBHOOK_MAX_RETRIES=3
WEBHOOK_RETRY_DELAY=1

# ============================================
# Analytics Configuration
# ============================================
ENABLE_ANALYTICS_SNAPSHOTS=true
ANALYTICS_SNAPSHOT_HOUR=3
